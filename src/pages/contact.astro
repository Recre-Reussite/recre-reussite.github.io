---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { Phone, Mail, MapPin, Send, Clock } from "@lucide/astro";
---

<BaseLayout title="Contact">
  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Decorative -->
    <div class="absolute inset-0 scattered-dots pointer-events-none"></div>
    <div
      class="absolute top-20 right-16 w-20 h-20 bg-sky/10 puzzle-piece rotate-12 float"
    >
    </div>
    <div
      class="absolute bottom-20 left-10 w-16 h-16 bg-cta/8 puzzle-piece -rotate-6 float-delay"
    >
    </div>

    <div class="relative max-w-[1140px] mx-auto px-6">
      <SectionHeading
        subtitle="Contact"
        title="Parlons de vos besoins"
        accent="besoins"
      />

      <div class="max-w-[950px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-8">
        <!-- Form -->
        <div class="md:col-span-7 bg-card rounded-card shadow-lg p-8 md:p-10">
          <div class="flex items-center gap-3 mb-8">
            <div
              class="w-12 h-12 dashed-circle flex items-center justify-center text-primary"
            >
              <Send class="w-6 h-6" />
            </div>
            <h2 class="font-display text-primary text-2xl">
              Envoyer un message
            </h2>
          </div>

          <form action="#" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block font-bold text-sm text-text mb-2">
                Nom <span class="text-pink">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Votre nom"
                class="w-full border-2 border-border rounded-card px-4 py-3 font-semibold focus:border-primary focus:outline-none transition-colors bg-background"
              />
            </div>
            <div>
              <label for="email" class="block font-bold text-sm text-text mb-2">
                E-mail <span class="text-pink">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="votre@email.fr"
                class="w-full border-2 border-border rounded-card px-4 py-3 font-semibold focus:border-primary focus:outline-none transition-colors bg-background"
              />
            </div>
            <div>
              <label for="phone" class="block font-bold text-sm text-text mb-2">
                Téléphone
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="06 XX XX XX XX"
                class="w-full border-2 border-border rounded-card px-4 py-3 font-semibold focus:border-primary focus:outline-none transition-colors bg-background"
              />
            </div>
            <div>
              <label
                for="message"
                class="block font-bold text-sm text-text mb-2"
              >
                Message <span class="text-pink">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Comment puis-je vous aider ?"
                class="w-full border-2 border-border rounded-card px-4 py-3 font-semibold focus:border-primary focus:outline-none transition-colors bg-background resize-y"
              ></textarea>
            </div>
            <div class="hidden" aria-hidden="true">
              <input
                type="text"
                name="_gotcha"
                tabindex="-1"
                autocomplete="off"
              />
            </div>
            <Button type="submit" variant="primary" class="w-full text-center">
              Envoyer
            </Button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="md:col-span-5 flex flex-col gap-6">
          <div class="bg-card rounded-card shadow-lg p-8">
            <h3 class="font-display text-primary text-xl mb-6">Coordonnées</h3>
            <div class="space-y-5">
              <a href="tel:+33607790026" class="flex items-center gap-4 group">
                <div
                  class="w-12 h-12 dashed-circle flex items-center justify-center text-cta shrink-0 group-hover:scale-110 transition-transform"
                >
                  <Phone class="w-6 h-6" />
                </div>
                <div>
                  <p
                    class="text-xs font-bold text-text-light uppercase tracking-wider"
                  >
                    Téléphone
                  </p>
                  <p class="font-bold text-text">06 07 79 00 26</p>
                </div>
              </a>
              <a
                href="mailto:recre-reussite@outlook.fr"
                class="flex items-center gap-4 group"
              >
                <div
                  class="w-12 h-12 dashed-circle flex items-center justify-center text-sky shrink-0 group-hover:scale-110 transition-transform"
                >
                  <Mail class="w-6 h-6" />
                </div>
                <div>
                  <p
                    class="text-xs font-bold text-text-light uppercase tracking-wider"
                  >
                    Email
                  </p>
                  <p class="font-bold text-text break-all">
                    recre-reussite@outlook.fr
                  </p>
                </div>
              </a>
              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 dashed-circle flex items-center justify-center text-secondary shrink-0"
                >
                  <MapPin class="w-6 h-6" />
                </div>
                <div>
                  <p
                    class="text-xs font-bold text-text-light uppercase tracking-wider"
                  >
                    Zone
                  </p>
                  <p class="font-bold text-text">Caen et alentours (14)</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-cream rounded-card p-6 flex items-start gap-4">
            <div
              class="w-10 h-10 dashed-circle flex items-center justify-center text-purple shrink-0 mt-1"
            >
              <Clock class="w-5 h-5" />
            </div>
            <p class="text-text-light font-semibold leading-relaxed text-sm">
              Je vous répondrai dans les meilleurs délais. Vous pouvez également
              me joindre directement par téléphone.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
