---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";
import {
  CircleCheck,
  CircleX,
  Star,
  School,
  BookOpen,
  Bike,
  Users,
  CookingPot,
  Puzzle,
  CalendarDays,
  TreePine,
  HandHeart,
} from "@lucide/astro";
---

<BaseLayout title="Présentation">
  <!-- ============================================
       HERO — merged header + services
       ============================================ -->
  <section class="relative pt-10 pb-14 md:pt-16 md:pb-20 overflow-hidden bg-cover bg-bottom bg-no-repeat" style="background-image: url('/images/banner.png');">
    <!-- Overlay for readability -->
    <div class="absolute inset-0 bg-background/80"></div>

    <div
      class="relative max-w-[1140px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
      <!-- Text + services -->
      <div class="text-center md:text-left">
        <h1
          class="font-display text-[38px] md:text-[56px] leading-[1.1] text-primary uppercase"
        >
          Récré <span class="text-cta">&</span>
          <span class="text-secondary">Réussite</span>
        </h1>
        <p
          class="mt-6 text-lg text-text-light leading-relaxed max-w-md mx-auto md:mx-0"
        >
          J'accompagne vos enfants avec bienveillance à Caen et ses alentours.
        </p>

        <!-- Service icons row -->
        <div class="mt-8 grid grid-cols-2 gap-6 max-w-md mx-auto md:mx-0">
          {
            [
              {
                icon: Users,
                label: "Garde d'enfants",
                color: "text-primary",
                desc: "À votre domicile, en toute confiance",
              },
              {
                icon: BookOpen,
                label: "Aide aux devoirs",
                color: "text-secondary",
                desc: "Apprentissage ludique et motivant",
              },
              {
                icon: School,
                label: "Sortie d'école",
                color: "text-cta",
                desc: "Récupération et retour au domicile",
              },
              {
                icon: Puzzle,
                label: "Activités & Jeux",
                color: "text-purple",
                desc: "Créativité, jeux, sorties",
              },
            ].map(({ icon: Icon, label, color, desc }) => (
              <div class="flex items-start gap-3 group">
                <div
                  class:list={[
                    "w-12 h-12 dashed-circle flex items-center justify-center shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3",
                    color,
                  ]}
                >
                  <Icon class="w-6 h-6" />
                </div>
                <div>
                  <h3 class="font-bold text-text text-sm mb-0.5">{label}</h3>
                  <p class="text-text-light text-xs leading-relaxed">{desc}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="mt-8 flex gap-4 justify-center md:justify-start">
          <Button href="/contact">Me contacter</Button>
          <p class="mt-2 text-sm font-bold text-text-light">
            De la maternelle à la 3ᵉ<br />
            Le soir, les mercredis, les vacances scolaires.
          </p>
          <p class="mt-3 text-sm font-bold text-text-light"></p>
        </div>
      </div>

      <!-- Logo — large, no circles -->
      <div class="flex justify-center">
        <img
          src="/images/logo-recre-reussite.png"
          alt="Logo Récré & Réussite"
          class="w-64 md:w-80 lg:w-96 h-auto drop-shadow-lg"
        />
      </div>
    </div>
  </section>

  <!-- ============================================
       ABOUT JULIE — organic, warm
       ============================================ -->
  <section class="relative py-16 md:py-24 overflow-hidden bg-card">
    <div
      class="absolute top-10 right-20 w-20 h-20 bg-yellow/10 puzzle-piece rotate-12 float-delay"
    >
    </div>

    <div class="max-w-[900px] mx-auto px-6 reveal">
      <SectionHeading subtitle="Présentation" title="Qui suis-je ?" />

      <div class="bg-card rounded-card overflow-hidden shadow-lg">
        <div class="flex flex-col md:flex-row">
          <!-- Color accent side -->
          <div class="md:w-1/3 min-h-[250px]">
            <img
              src="/images/julie.jpg"
              alt="Julie — Récré & Réussite"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Text -->
          <div class="md:w-2/3 p-8 md:p-10 space-y-4">
            <p class="text-lg leading-relaxed text-text-light">
              Je suis Julie, AESH depuis 2019, je m'occupe d'enfants en
              parallèle pour différentes structures depuis toujours. D'abord en
              centre de loisirs grâce à mon BAFA, puis au domicile des
              particuliers pour des associations et entreprises.
            </p>
            <p class="text-lg leading-relaxed text-text-light">
              Aujourd'hui, j'ai créé
              <strong class="text-cta font-extrabold">Récré & Réussite</strong>
              pour vous apporter une solution de garde personnalisée, correspondant
              au mieux à vos besoins et ceux de vos enfants.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       JE PEUX / JE NE PEUX PAS
       ============================================ -->
  <section class="bg-background py-16 md:py-24">
    <div class="max-w-[1140px] mx-auto px-6 reveal">
      <SectionHeading
        subtitle="Services"
        title="Ce que je propose"
        accent="propose"
      />

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-[1000px] mx-auto"
      >
        <!-- JE PEUX -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div
              class="w-10 h-10 bg-secondary/15 rounded-full flex items-center justify-center"
            >
              <CircleCheck class="w-6 h-6 text-secondary" />
            </div>
            <h3 class="font-display text-secondary text-2xl">Ce que je fais</h3>
          </div>
          <div class="space-y-4">
            {
              [
                {
                  text: "Enfants à besoin particulier",
                  icon: HandHeart,
                  color: "text-pink",
                },
                {
                  text: "Sortie d'école & retour au domicile",
                  icon: School,
                  color: "text-primary",
                },
                {
                  text: "Trajets activités extra-scolaires",
                  icon: Bike,
                  color: "text-purple",
                },
                {
                  text: "Cuisiner avec vos enfants",
                  icon: CookingPot,
                  color: "text-cta",
                },
                {
                  text: "Aide aux devoirs",
                  icon: BookOpen,
                  color: "text-secondary",
                },
                {
                  text: "Activités manuelles & jeux de société",
                  icon: Puzzle,
                  color: "text-sky",
                },
                {
                  text: "Sorties en plein air",
                  icon: TreePine,
                  color: "text-secondary",
                },
                {
                  text: "Sorties avec plusieurs enfants",
                  icon: Users,
                  color: "text-primary",
                },
              ].map(({ text, icon: Icon, color }) => (
                <div class="flex items-center gap-4 group">
                  <div
                    class:list={[
                      "w-10 h-10 dashed-circle flex items-center justify-center shrink-0 transition-transform group-hover:scale-110",
                      color,
                    ]}
                  >
                    <Icon class="w-5 h-5" />
                  </div>
                  <span class="font-semibold text-text">{text}</span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- RIGHT: Je ne fais pas + Dispos -->
        <div class="space-y-10">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-10 h-10 bg-pink/15 rounded-full flex items-center justify-center"
              >
                <CircleX class="w-6 h-6 text-pink" />
              </div>
              <h3 class="font-display text-pink text-2xl">
                Ce que je ne fais pas
              </h3>
            </div>
            <div class="space-y-3">
              {
                [
                  "Enfants de moins de 3 ans",
                  "Garde le week-end",
                  "Gestion administrative CAF / impôts",
                ].map((item) => (
                  <div class="flex items-center gap-3 text-text-light">
                    <CircleX class="w-5 h-5 text-pink/50 shrink-0" />
                    <span class="font-semibold">{item}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="bg-ice rounded-card p-6">
            <div class="flex items-center gap-3 mb-4">
              <CalendarDays class="w-6 h-6 text-primary" />
              <h3 class="font-display text-primary text-xl">Disponibilités</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-3">
              {
                ["Les soirs", "Les mercredis", "Les vacances scolaires"].map(
                  (time) => (
                    <span class="bg-primary/10 text-primary font-bold px-4 py-1.5 rounded-pill text-sm">
                      {time}
                    </span>
                  ),
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       TESTIMONIAL
       ============================================ -->
  <section class="bg-card py-16 md:py-24 relative overflow-hidden">
    <div
      class="absolute bottom-10 right-16 w-16 h-16 bg-cta/8 puzzle-piece -rotate-6 float"
    >
    </div>

    <div class="max-w-[750px] mx-auto px-6 text-center reveal">
      <SectionHeading
        subtitle="Témoignage"
        title="Ce qu'ils en disent"
        accent="disent"
      />

      <div class="flex justify-center gap-1 mb-8">
        {
          [1, 2, 3, 4, 5].map(() => (
            <Star class="w-7 h-7 text-yellow fill-yellow" />
          ))
        }
      </div>

      <blockquote
        class="text-lg md:text-xl italic leading-relaxed text-text-light mb-8"
      >
        « J'aime bien qu'on fasse des activités ensemble comme le coloriage
        magique. Julie est trop cool et très gentille. Elle m'aide beaucoup pour
        faire mes devoirs même si je n'ai pas toujours envie. Elle me récupère à
        l'école. On a fait plein de balades à pied, en vélo ou en trottinette.
        Elle m'amène aux répétitions du conservatoire. »
      </blockquote>

      <div class="flex items-center justify-center gap-3">
        <div
          class="w-12 h-12 bg-cta/15 rounded-full flex items-center justify-center text-cta font-display text-xl"
        >
          É
        </div>
        <span class="font-bold text-primary text-lg">Élise</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       GALLERY
       ============================================ -->
  <section class="py-16 md:py-24">
    <div class="max-w-[1140px] mx-auto px-6 reveal">
      <SectionHeading
        subtitle="En images"
        title="Moments partagés"
        accent="partagés"
      />
      <div
        class="relative overflow-hidden rounded-card shadow-lg"
        id="photo-carousel"
      >
        <div
          class="flex transition-transform duration-500 ease-in-out"
          id="carousel-track"
        >
          {
            [
              {
                src: "/images/photo-01.jpg",
                alt: "Activités avec les enfants",
                portrait: false,
              },
              {
                src: "/images/photo-02.jpg",
                alt: "Moments de partage",
                portrait: true,
              },
              {
                src: "/images/photo-03.png",
                alt: "Sorties et découvertes",
                portrait: true,
              },
            ].map(({ src, alt, portrait }) => (
              <div class="w-full flex-shrink-0 aspect-[16/9] relative overflow-hidden">
                {portrait ? (
                  <>
                    <img
                      src={src}
                      alt=""
                      aria-hidden="true"
                      class="absolute inset-0 w-full h-full object-cover blur-2xl scale-110 brightness-75"
                    />
                    <img
                      src={src}
                      alt={alt}
                      class="relative h-full mx-auto object-contain z-10"
                      loading="lazy"
                    />
                  </>
                ) : (
                  <img
                    src={src}
                    alt={alt}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                )}
              </div>
            ))
          }
        </div>
        <button
          id="carousel-prev"
          aria-label="Photo précédente"
          class="absolute left-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center shadow-md transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="15 18 9 12 15 6"></polyline></svg
          >
        </button>
        <button
          id="carousel-next"
          aria-label="Photo suivante"
          class="absolute right-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center shadow-md transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="9 18 15 12 9 6"></polyline></svg
          >
        </button>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
          {
            [0, 1, 2].map((i) => (
              <button
                class:list={[
                  "carousel-dot w-3 h-3 rounded-full transition-colors cursor-pointer",
                  i === 0 ? "bg-white" : "bg-white/50",
                ]}
                data-index={i}
                aria-label={`Aller à la photo ${i + 1}`}
              />
            ))
          }
        </div>
      </div>

      <script>
        const track = document.getElementById("carousel-track") as HTMLElement;
        const dots = document.querySelectorAll(".carousel-dot");
        const total = 3;
        let current = 0;
        let autoplayTimer: ReturnType<typeof setInterval>;

        function goTo(index: number) {
          current = ((index % total) + total) % total;
          track.style.transform = `translateX(-${current * 100}%)`;
          dots.forEach((dot, i) => {
            dot.classList.toggle("bg-white", i === current);
            dot.classList.toggle("bg-white/50", i !== current);
          });
        }

        function startAutoplay() {
          autoplayTimer = setInterval(() => goTo(current + 1), 5000);
        }

        function resetAutoplay() {
          clearInterval(autoplayTimer);
          startAutoplay();
        }

        document
          .getElementById("carousel-prev")!
          .addEventListener("click", () => {
            goTo(current - 1);
            resetAutoplay();
          });
        document
          .getElementById("carousel-next")!
          .addEventListener("click", () => {
            goTo(current + 1);
            resetAutoplay();
          });
        dots.forEach((dot) => {
          dot.addEventListener("click", () => {
            goTo(Number((dot as HTMLElement).dataset.index));
            resetAutoplay();
          });
        });

        startAutoplay();
      </script>
    </div>
  </section>
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
