---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Doodle from "../components/Doodle.astro";
import {
  CircleCheck,
  CircleX,
  Star,
  School,
  BookOpen,
  Bike,
  Users,
  CookingPot,
  Puzzle,
  CalendarDays,
  TreePine,
  HandHeart,
  ChevronLeft,
  ChevronRight,
} from "@lucide/astro";

import logoImg from "../assets/images/logo-recre-reussite.png";
import julieImg from "../assets/images/julie.jpg";
import photo01 from "../assets/images/photo-01.jpg";
import photo02 from "../assets/images/photo-02.jpg";
import photo03 from "../assets/images/photo-03.png";

const testimonials = [
  {
    quote:
      "Julie a gardé nos deux enfants pendant près d'un an et nous avons été très satisfaits. Elle était ponctuelle, organisée et savait s'adapter à nos horaires qui changeaient souvent. Les enfants étaient toujours contents quand elle arrivait, c'était le meilleur indicateur pour nous.",
    name: "Sophie, maman de 2 enfants",
    initial: "S",
    type: "parent" as const,
  },
  {
    quote:
      "Notre fils est autiste et nous avions du mal à trouver une personne de confiance qui sache l'accompagner au quotidien. Julie a pris le temps de comprendre son fonctionnement, ses besoins et ses rituels. Elle fait preuve d'une patience et d'une bienveillance remarquables. Pour la première fois, nous le laissons sereinement.",
    name: "Marc, papa",
    initial: "M",
    type: "parent" as const,
  },
  {
    quote:
      "J'aime bien qu'on fasse des activités ensemble comme le coloriage magique. Julie est trop cool et très gentille. Elle m'aide beaucoup pour faire mes devoirs même si je n'ai pas toujours envie. Elle me récupère à l'école. On a fait plein de balades à pied, en vélo ou en trottinette. Elle m'amène aux répétitions du conservatoire.",
    name: "Élise, 11 ans",
    initial: "É",
    type: "enfant" as const,
  },
];
---

<BaseLayout
  title="Présentation"
  description="Récré & Réussite — Garde d'enfants à domicile à Caen. Sortie d'école, aide aux devoirs, activités ludiques et accompagnement bienveillant par Julie, AESH diplômée BAFA."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Récré & Réussite",
      "description": "Garde d'enfants à domicile à Caen et ses alentours. Sortie d'école, aide aux devoirs, activités ludiques.",
      "url": "https://recre-reussite.fr",
      "image": "https://recre-reussite.fr/images/banner.png",
      "telephone": "",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Caen",
        "addressRegion": "Normandie",
        "addressCountry": "FR"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": 49.1829,
          "longitude": -0.3707
        },
        "geoRadius": "30000"
      },
      "serviceType": ["Garde d'enfants à domicile", "Aide aux devoirs", "Sortie d'école", "Activités ludiques"],
      "priceRange": "€€"
    })} />
  </Fragment>
  <!-- ============================================
       HERO — bold, playful, Langmobile-inspired
       ============================================ -->
  <section class="relative pt-10 pb-6 md:pt-16 md:pb-10 overflow-hidden bg-background">
    <!-- Subtle scattered dots background -->
    <div class="absolute inset-0 scattered-dots pointer-events-none"></div>

    <!-- Floating doodle decorations -->
    <div class="absolute top-16 left-[8%] hero-animate-doodle" style="animation-delay: 0.8s;">
      <Doodle type="star" color="var(--color-yellow)" size={35} class="float" />
    </div>
    <div class="absolute top-28 right-[10%] hero-animate-doodle hidden md:block" style="animation-delay: 1s;">
      <Doodle type="squiggle" color="var(--color-sky)" size={30} class="float-delay" />
    </div>
    <div class="absolute bottom-20 left-[15%] hero-animate-doodle hidden md:block" style="animation-delay: 1.2s;">
      <Doodle type="spiral" color="var(--color-purple)" size={35} class="float" />
    </div>
    <div class="absolute bottom-16 right-[18%] hero-animate-doodle hidden md:block" style="animation-delay: 0.9s;">
      <Doodle type="dots" color="var(--color-secondary)" size={30} class="float-delay" />
    </div>

    <div class="relative max-w-[1140px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
      <!-- Text + services -->
      <div class="text-center md:text-left">
        <h1 class="font-display leading-[1.05] uppercase hero-animate-title">
          <span class="text-primary text-[48px] md:text-[72px] lg:text-[80px] block">Récré</span>
          <span class="inline-block bg-cta text-white text-[44px] md:text-[64px] lg:text-[72px] px-4 py-1 rounded-lg -rotate-2 my-2 shadow-lg">&</span>
          <span class="text-secondary text-[48px] md:text-[72px] lg:text-[80px] block">Réussite</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-text-light leading-relaxed max-w-md mx-auto md:mx-0 hero-animate-subtitle">
          J'accompagne vos enfants avec bienveillance à Caen et ses alentours.
        </p>

        <!-- Service icons row -->
        <div class="mt-8 grid grid-cols-2 gap-5 max-w-md mx-auto md:mx-0 hero-animate-services">
          {
            [
              {
                icon: Users,
                label: "Garde d'enfants",
                color: "text-primary",
                bg: "bg-primary/10",
                desc: "À votre domicile, en toute confiance",
              },
              {
                icon: BookOpen,
                label: "Aide aux devoirs",
                color: "text-secondary",
                bg: "bg-secondary/10",
                desc: "Apprentissage ludique et motivant",
              },
              {
                icon: School,
                label: "Sortie d'école",
                color: "text-cta",
                bg: "bg-cta/10",
                desc: "Récupération et retour au domicile",
              },
              {
                icon: Puzzle,
                label: "Activités & Jeux",
                color: "text-purple",
                bg: "bg-purple/10",
                desc: "Créativité, jeux, sorties",
              },
            ].map(({ icon: Icon, label, color, bg, desc }) => (
              <div class:list={["flex items-start gap-3 group p-3 rounded-card transition-all duration-300 hover:shadow-md", bg]}>
                <div
                  class:list={[
                    "w-11 h-11 dashed-circle flex items-center justify-center shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6",
                    color,
                  ]}
                >
                  <Icon class="w-5 h-5" />
                </div>
                <div>
                  <p class="font-bold text-text text-sm mb-0.5">{label}</p>
                  <p class="text-text-light text-xs leading-relaxed">{desc}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 items-center justify-center md:justify-start hero-animate-cta">
          <Button href="/contact">Me contacter</Button>
          <p class="text-sm font-bold text-text-light text-center sm:text-left">
            De la maternelle à la 3ᵉ<br />
            Le soir, les mercredis, les vacances scolaires.
          </p>
        </div>
      </div>

      <!-- Logo — large, animated pop-in -->
      <div class="flex justify-center hero-animate-logo">
        <Image
          src={logoImg}
          alt="Logo Récré & Réussite"
          width={384}
          class="w-56 md:w-72 lg:w-96 h-auto drop-shadow-xl"
        />
      </div>
    </div>
  </section>


  <!-- ============================================
       ABOUT JULIE — organic, warm
       ============================================ -->
  <section class="relative py-16 md:py-24 overflow-hidden bg-card">
    <!-- Floating decorations -->
    <div class="absolute bottom-12 left-10 hidden md:block">
      <Doodle type="star" color="var(--color-secondary)" size={28} class="float opacity-40" />
    </div>
    <div class="absolute top-20 left-16 hidden md:block">
      <Doodle type="squiggle" color="var(--color-sky)" size={24} class="float-delay opacity-30" />
    </div>

    <div class="max-w-[900px] mx-auto px-6 reveal">
      <SectionHeading subtitle="Présentation" title="Qui suis-je ?" />

      <div class="bg-card rounded-card overflow-hidden shadow-lg relative">
        <!-- Decorative dashed border accent -->
        <div class="absolute -top-2 -left-2 -right-2 -bottom-2 border-3 border-dashed border-primary/15 rounded-[1.5rem] pointer-events-none"></div>

        <div class="flex flex-col md:flex-row">
          <!-- Photo with decorative frame -->
          <div class="md:w-1/3 min-h-[250px] relative">
            <Image
              src={julieImg}
              alt="Julie — Récré & Réussite"
              width={400}
              class="w-full h-full object-cover md:-rotate-1 transition-transform duration-500 hover:rotate-0 hover:scale-105"
            />
            <!-- Photo corner decoration -->
          </div>
          <!-- Text -->
          <div class="md:w-2/3 p-8 md:p-10 space-y-4">
            <p class="text-lg leading-relaxed text-text-light">
              Je suis Julie, AESH depuis 2019, je m'occupe d'enfants en
              parallèle pour différentes structures depuis toujours. D'abord en
              centre de loisirs grâce à mon BAFA, puis au domicile des
              particuliers pour des associations et entreprises.
            </p>
            <p class="text-lg leading-relaxed text-text-light">
              Aujourd'hui, j'ai créé
              <strong class="text-cta font-extrabold">Récré & Réussite</strong>
              pour vous apporter une solution de garde personnalisée, correspondant
              au mieux à vos besoins et ceux de vos enfants.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================
       JE PEUX / JE NE PEUX PAS
       ============================================ -->
  <section class="bg-background py-16 md:py-24 relative overflow-hidden">
    <!-- Floating decorations -->
    <div class="absolute top-16 right-12 hidden md:block">
      <Doodle type="zigzag" color="var(--color-secondary)" size={25} class="float opacity-25" />
    </div>
    <div class="absolute bottom-20 left-8 hidden md:block">
      <Doodle type="circle" color="var(--color-purple)" size={40} class="float-delay opacity-20" />
    </div>

    <div class="max-w-[1140px] mx-auto px-6 reveal">
      <SectionHeading
        subtitle="Services"
        title="Ce que je propose"
        accent="propose"
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-[1000px] mx-auto">
        <!-- JE PEUX -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-secondary/15 rounded-full flex items-center justify-center">
              <CircleCheck class="w-6 h-6 text-secondary" />
            </div>
            <h3 class="font-display text-secondary text-2xl">Ce que je fais</h3>
          </div>
          <div class="space-y-3 stagger-children" id="services-list">
            {
              [
                { text: "Enfants à besoin particulier", icon: HandHeart, color: "text-pink", bg: "bg-pink/8" },
                { text: "Sortie d'école & retour au domicile", icon: School, color: "text-primary", bg: "bg-primary/8" },
                { text: "Trajets activités extra-scolaires", icon: Bike, color: "text-purple", bg: "bg-purple/8" },
                { text: "Cuisiner avec vos enfants", icon: CookingPot, color: "text-cta", bg: "bg-cta/8" },
                { text: "Aide aux devoirs", icon: BookOpen, color: "text-secondary", bg: "bg-secondary/8" },
                { text: "Activités manuelles & jeux de société", icon: Puzzle, color: "text-sky", bg: "bg-sky/8" },
                { text: "Sorties en plein air", icon: TreePine, color: "text-cta", bg: "bg-cta/8" },
                { text: "Sorties avec plusieurs enfants", icon: Users, color: "text-primary", bg: "bg-primary/8" },
              ].map(({ text, icon: Icon, color, bg }) => (
                <div class:list={["flex items-center gap-4 group p-3 rounded-card transition-all duration-300 hover:shadow-md cursor-default", bg]}>
                  <div
                    class:list={[
                      "w-10 h-10 dashed-circle flex items-center justify-center shrink-0 transition-transform group-hover:scale-110 group-hover:rotate-6",
                      color,
                    ]}
                  >
                    <Icon class="w-5 h-5" />
                  </div>
                  <span class="font-semibold text-text">{text}</span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- RIGHT: Je ne fais pas + Dispos -->
        <div class="space-y-10">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-pink/15 rounded-full flex items-center justify-center">
                <CircleX class="w-6 h-6 text-pink" />
              </div>
              <h3 class="font-display text-pink text-2xl">
                Ce que je ne fais pas
              </h3>
            </div>
            <div class="space-y-3">
              {
                [
                  "Enfants de moins de 3 ans",
                  "Garde le week-end",
                  "Gestion administrative CAF / impôts",
                ].map((item) => (
                  <div class="flex items-center gap-3 text-text-light p-2 rounded-lg hover:bg-pink/5 transition-colors">
                    <CircleX class="w-5 h-5 text-pink/50 shrink-0" />
                    <span class="font-semibold">{item}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="bg-ice rounded-card p-6 card-hover shadow-sm">
            <div class="flex items-center gap-3 mb-4">
              <CalendarDays class="w-6 h-6 text-primary" />
              <h3 class="font-display text-primary text-xl">Disponibilités</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-3">
              {
                ["Les soirs", "Les mercredis", "Les vacances scolaires"].map(
                  (time) => (
                    <span class="bg-primary/10 text-primary font-bold px-4 py-1.5 rounded-pill text-sm transition-colors hover:bg-primary/20">
                      {time}
                    </span>
                  ),
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================
       TESTIMONIALS CAROUSEL
       ============================================ -->
  <section class="bg-card py-16 md:py-24 relative overflow-hidden">
    <!-- Floating decorations -->
    <div class="absolute top-12 left-12 hidden md:block">
      <Doodle type="star" color="var(--color-yellow)" size={30} class="float opacity-40" />
    </div>
    <div class="absolute top-20 right-24 hidden md:block">
      <Doodle type="dots" color="var(--color-sky)" size={25} class="float-delay opacity-30" />
    </div>

    <div class="max-w-[750px] mx-auto px-6 text-center reveal">
      <SectionHeading
        subtitle="Témoignages"
        title="Ce qu'ils en disent"
        accent="disent"
      />

      <div class="flex justify-center gap-1.5 mb-8">
        {
          [1, 2, 3, 4, 5].map((_, i) => (
            <Star class="w-8 h-8 text-yellow fill-yellow" style={`animation: hero-pop 0.4s ease-out ${0.1 * i}s both;`} />
          ))
        }
      </div>

      <!-- Carousel container -->
      <div id="testimonial-carousel" class="relative">
        {testimonials.map((t, index) => (
          <div
            class:list={[
              "testimonial-slide transition-opacity duration-500",
              index === 0 ? "opacity-100" : "opacity-0 absolute inset-0 pointer-events-none",
            ]}
            data-index={index}
          >
            <!-- Quote card -->
            <div class="relative bg-cream/50 rounded-card p-8 md:p-10 mb-8">
              <span class="absolute -top-4 left-6 text-6xl text-secondary/20 font-display leading-none">&laquo;</span>
              <blockquote class="text-lg md:text-xl italic leading-relaxed text-text-light relative z-10">
                {t.quote}
              </blockquote>
              <span class="absolute -bottom-4 right-6 text-6xl text-secondary/20 font-display leading-none">&raquo;</span>
            </div>

            <!-- Author -->
            <div class="flex items-center justify-center gap-3">
              <div class:list={[
                "w-12 h-12 rounded-full flex items-center justify-center font-display text-xl",
                t.type === "enfant" ? "bg-cta/15 text-cta" : "bg-purple/15 text-purple",
              ]}>
                {t.initial}
              </div>
              <div class="flex flex-col items-start">
                <span class="font-bold text-primary text-lg">{t.name}</span>
                <span class:list={[
                  "text-xs font-bold uppercase tracking-wide px-2 py-0.5 rounded-pill",
                  t.type === "enfant"
                    ? "bg-sky/15 text-sky"
                    : "bg-purple/15 text-purple",
                ]}>
                  {t.type === "enfant" ? "Enfant" : "Parent"}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation -->
      <div class="flex items-center justify-center gap-6 mt-8">
        <button
          type="button"
          id="testimonial-prev"
          aria-label="Témoignage précédent"
          class="w-10 h-10 rounded-full border-2 border-border bg-background flex items-center justify-center text-text hover:border-primary hover:text-primary transition-colors cursor-pointer"
        >
          <ChevronLeft class="w-5 h-5" />
        </button>

        <div class="flex gap-2" id="testimonial-dots">
          {testimonials.map((_, i) => (
            <button
              type="button"
              aria-label={`Témoignage ${i + 1}`}
              data-dot={i}
              class:list={[
                "w-3 h-3 rounded-full transition-all duration-300 cursor-pointer",
                i === 0 ? "bg-primary scale-125" : "bg-border hover:bg-primary/50",
              ]}
            />
          ))}
        </div>

        <button
          type="button"
          id="testimonial-next"
          aria-label="Témoignage suivant"
          class="w-10 h-10 rounded-full border-2 border-border bg-background flex items-center justify-center text-text hover:border-primary hover:text-primary transition-colors cursor-pointer"
        >
          <ChevronRight class="w-5 h-5" />
        </button>
      </div>
    </div>
  </section>


  <!-- ============================================
       GALLERY
       ============================================ -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <!-- Floating decorations -->
    <div class="absolute top-8 right-16 hidden md:block">
      <Doodle type="spiral" color="var(--color-purple)" size={30} class="float opacity-25" />
    </div>
    <div class="max-w-[1140px] mx-auto px-6 reveal">
      <SectionHeading
        subtitle="En images"
        title="Moments partagés"
        accent="partagés"
      />
      <div
        class="relative overflow-hidden rounded-card shadow-lg"
        id="photo-carousel"
      >
        <div
          class="flex transition-transform duration-500 ease-in-out"
          id="carousel-track"
        >
          {
            [
              { src: photo01, alt: "Activités avec les enfants", portrait: false },
              { src: photo02, alt: "Moments de partage", portrait: true },
              { src: photo03, alt: "Sorties et découvertes", portrait: true },
            ].map(({ src, alt, portrait }) => (
              <div class="w-full flex-shrink-0 aspect-[16/9] relative overflow-hidden">
                {portrait ? (
                  <>
                    <Image
                      src={src}
                      alt=""
                      width={1280}
                      aria-hidden="true"
                      class="absolute inset-0 w-full h-full object-cover blur-2xl scale-110 brightness-75"
                      loading="lazy"
                    />
                    <Image
                      src={src}
                      alt={alt}
                      width={720}
                      class="relative h-full mx-auto object-contain z-10"
                      loading="lazy"
                    />
                  </>
                ) : (
                  <Image
                    src={src}
                    alt={alt}
                    width={1280}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                )}
              </div>
            ))
          }
        </div>
        <button
          id="carousel-prev"
          aria-label="Photo précédente"
          class="absolute left-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center shadow-md transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="15 18 9 12 15 6"></polyline></svg
          >
        </button>
        <button
          id="carousel-next"
          aria-label="Photo suivante"
          class="absolute right-3 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center shadow-md transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="9 18 15 12 9 6"></polyline></svg
          >
        </button>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
          {
            [0, 1, 2].map((i) => (
              <button
                class:list={[
                  "carousel-dot w-3 h-3 rounded-full transition-colors cursor-pointer",
                  i === 0 ? "bg-white" : "bg-white/50",
                ]}
                data-index={i}
                aria-label={`Aller à la photo ${i + 1}`}
              />
            ))
          }
        </div>
      </div>

      <script>
        const track = document.getElementById("carousel-track") as HTMLElement;
        const dots = document.querySelectorAll(".carousel-dot");
        const total = 3;
        let current = 0;
        let autoplayTimer: ReturnType<typeof setInterval>;

        function goTo(index: number) {
          current = ((index % total) + total) % total;
          track.style.transform = `translateX(-${current * 100}%)`;
          dots.forEach((dot, i) => {
            dot.classList.toggle("bg-white", i === current);
            dot.classList.toggle("bg-white/50", i !== current);
          });
        }

        function startAutoplay() {
          autoplayTimer = setInterval(() => goTo(current + 1), 5000);
        }

        function resetAutoplay() {
          clearInterval(autoplayTimer);
          startAutoplay();
        }

        document
          .getElementById("carousel-prev")!
          .addEventListener("click", () => {
            goTo(current - 1);
            resetAutoplay();
          });
        document
          .getElementById("carousel-next")!
          .addEventListener("click", () => {
            goTo(current + 1);
            resetAutoplay();
          });
        dots.forEach((dot) => {
          dot.addEventListener("click", () => {
            goTo(Number((dot as HTMLElement).dataset.index));
            resetAutoplay();
          });
        });

        startAutoplay();
      </script>
    </div>
  </section>
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );

    document.querySelectorAll(".reveal, .stagger-children").forEach((el) => observer.observe(el));
  </script>

  <script>
    // Testimonial carousel
    const slides = document.querySelectorAll<HTMLElement>(".testimonial-slide");
    const dots = document.querySelectorAll<HTMLElement>("#testimonial-dots button");
    const prevBtn = document.getElementById("testimonial-prev")!;
    const nextBtn = document.getElementById("testimonial-next")!;
    let currentSlide = 0;

    function showSlide(index: number) {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.classList.remove("opacity-0", "absolute", "inset-0", "pointer-events-none");
          slide.classList.add("opacity-100");
        } else {
          slide.classList.remove("opacity-100");
          slide.classList.add("opacity-0", "absolute", "inset-0", "pointer-events-none");
        }
      });
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove("bg-border", "hover:bg-primary/50");
          dot.classList.add("bg-primary", "scale-125");
        } else {
          dot.classList.remove("bg-primary", "scale-125");
          dot.classList.add("bg-border", "hover:bg-primary/50");
        }
      });
      currentSlide = index;
    }

    // Auto-scroll every 15 seconds, reset on user interaction
    let autoPlayTimer = setInterval(() => {
      showSlide((currentSlide + 1) % slides.length);
    }, 15000);

    function resetAutoPlay() {
      clearInterval(autoPlayTimer);
      autoPlayTimer = setInterval(() => {
        showSlide((currentSlide + 1) % slides.length);
      }, 15000);
    }

    prevBtn.addEventListener("click", () => {
      showSlide((currentSlide - 1 + slides.length) % slides.length);
      resetAutoPlay();
    });

    nextBtn.addEventListener("click", () => {
      showSlide((currentSlide + 1) % slides.length);
      resetAutoPlay();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        showSlide(Number(dot.dataset.dot));
        resetAutoPlay();
      });
    });
  </script>
</BaseLayout>
