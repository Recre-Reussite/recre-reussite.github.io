---
interface Props {
  color?: string;
  flip?: boolean;
}

const { color = "#F5F0E8", flip = false } = Astro.props;
---

<div class:list={["w-full overflow-hidden leading-none", flip && "rotate-180"]}>
  <svg
    viewBox="0 0 1440 80"
    preserveAspectRatio="none"
    class="block w-full h-12 md:h-16"
    fill={color}
  >
    <path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z" />
  </svg>
</div>
