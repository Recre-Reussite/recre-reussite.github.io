---
interface Props {
  type: "squiggle" | "star" | "dots" | "zigzag" | "circle" | "spiral" | "underline" | "arrow" | "sparkle";
  color?: string;
  size?: number;
  class?: string;
}

const { type, color = "currentColor", size = 40 } = Astro.props;
const className = Astro.props.class ?? "";
---

{type === "squiggle" && (
  <svg width={size * 2.5} height={size * 0.6} viewBox="0 0 100 24" fill="none" class:list={["inline-block", className]}>
    <path
      d="M2 12c8-10 16 10 24 0s16 10 24 0 16 10 24 0 16 10 24 0"
      stroke={color}
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
  </svg>
)}

{type === "star" && (
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" class:list={["inline-block", className]}>
    <path
      d="M20 2l3 12h12l-10 7 4 12-9-7-9 7 4-12L5 14h12z"
      fill={color}
      opacity="0.85"
    />
  </svg>
)}

{type === "dots" && (
  <svg width={size * 1.5} height={size * 0.6} viewBox="0 0 60 24" fill="none" class:list={["inline-block", className]}>
    <circle cx="6" cy="12" r="4" fill={color} opacity="0.6" />
    <circle cx="22" cy="8" r="3" fill={color} opacity="0.4" />
    <circle cx="36" cy="14" r="5" fill={color} opacity="0.5" />
    <circle cx="52" cy="10" r="3.5" fill={color} opacity="0.3" />
  </svg>
)}

{type === "zigzag" && (
  <svg width={size * 2} height={size * 0.5} viewBox="0 0 80 20" fill="none" class:list={["inline-block", className]}>
    <path
      d="M2 18L12 2l10 16L32 2l10 16L52 2l10 16L72 2l6 10"
      stroke={color}
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
  </svg>
)}

{type === "circle" && (
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" class:list={["inline-block", className]}>
    <circle
      cx="20" cy="20" r="15"
      stroke={color}
      stroke-width="2.5"
      stroke-dasharray="6 4"
      fill="none"
      opacity="0.7"
    />
  </svg>
)}

{type === "spiral" && (
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" class:list={["inline-block", className]}>
    <path
      d="M20 20c0-2 2-4 4-4s4 2 4 4-2 6-6 6-8-4-8-8 6-10 10-10 12 6 12 12"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      fill="none"
      opacity="0.6"
    />
  </svg>
)}

{type === "underline" && (
  <svg width={size * 3} height={size * 0.35} viewBox="0 0 120 14" fill="none" class:list={["inline-block", className]}>
    <path
      d="M2 8c20-6 40 4 60-2s40 6 56 0"
      stroke={color}
      stroke-width="3.5"
      stroke-linecap="round"
      fill="none"
    />
  </svg>
)}

{type === "arrow" && (
  <svg width={size * 1.5} height={size} viewBox="0 0 60 40" fill="none" class:list={["inline-block", className]}>
    <path
      d="M4 30c16-8 28-20 48-24M42 2l12 6-10 8"
      stroke={color}
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
  </svg>
)}

{type === "sparkle" && (
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" class:list={["inline-block", className]}>
    <path d="M20 4v32M4 20h32M8 8l24 24M32 8L8 32" stroke={color} stroke-width="2" stroke-linecap="round" opacity="0.7" />
  </svg>
)}
