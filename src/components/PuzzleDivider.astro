---
interface Props {
  topColor?: string;
  bottomColor?: string;
  tabPosition?: "left" | "center" | "right";
}

const {
  topColor = "#F5F0E8",
  bottomColor = "#FFFFFF",
  tabPosition = "center",
} = Astro.props;

// Positions X du centre de la languette
const positions = { left: 200, center: 720, right: 1240 };
const cx = positions[tabPosition];

const base = 40; // La ligne d'horizon
const headRadius = 35; // Rayon de la tête du puzzle
const neckWidth = 20; // Demi-largeur du col

const d = [
  // 1. On part du coin haut-gauche
  `M 0,0`,
  // 2. Ligne droite jusqu'au bord haut-droit
  `H 1440`,
  // 3. Descente jusqu'à la ligne de base
  `V ${base}`,
  // 4. Ligne droite jusqu'au début de l'attache (côté droit)
  `H ${cx + neckWidth + 20}`,

  // 5. COURBE DU PUZZLE (Tracé de droite à gauche)
  // Entrée vers le col (arrondi vers l'extérieur)
  `C ${cx + neckWidth},${base} ${cx + neckWidth},${base} ${cx + neckWidth},${base + 10}`,
  // Côté droit de la tête (on gonfle vers la droite puis on descend)
  `C ${cx + headRadius + 10},${base + 15} ${cx + headRadius + 10},${base + 65} ${cx},${base + 65}`,
  // Côté gauche de la tête (on remonte et on gonfle vers la gauche)
  `C ${cx - headRadius - 10},${base + 65} ${cx - headRadius - 10},${base + 15} ${cx - neckWidth},${base + 10}`,
  // Sortie du col vers la ligne de base
  `C ${cx - neckWidth},${base} ${cx - neckWidth},${base} ${cx - (neckWidth + 20)},${base}`,

  // 6. Finition de la ligne vers la gauche
  `H 0`,
  // 7. Fermeture de la forme
  `Z`,
].join(" ");
---

<div class="w-full leading-none" style={`background-color: ${bottomColor};`}>
  <svg
    viewBox="0 0 1440 120"
    preserveAspectRatio="none"
    class="block w-full h-20 md:h-28"
    fill={topColor}
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d={d}></path>
  </svg>
</div>
