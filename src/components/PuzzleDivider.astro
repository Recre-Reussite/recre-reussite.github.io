---
interface Props {
  topColor?: string;
  bottomColor?: string;
  tabPosition?: "left" | "center" | "right";
}

const {
  topColor = "#F5F0E8",
  bottomColor = "#FFFFFF",
  tabPosition = "center",
} = Astro.props;

// Tab center X positions
const positions = { left: 380, center: 720, right: 1060 };
const cx = positions[tabPosition];

// Classic puzzle connector shape:
//   ___/  \___     ← "ears" indent inward
//      |  |        ← narrow neck
//     /    \       ← head expands
//    (      )      ← round head
//     \____/
//
const base = 45; // baseline Y

const d = [
  // Fill the top section
  `M0,0 H1440 V${base}`,

  // Straight to right edge of connector opening
  `H${cx + 40}`,

  // Right "ear": edge curves INWARD (upward into the piece) — the locking indent
  `C${cx + 40},${base} ${cx + 36},${base - 8} ${cx + 14},${base - 8}`,

  // Right side of neck, then expands into head
  `C${cx + 14},${base - 8} ${cx + 14},${base + 12} ${cx + 32},${base + 22}`,

  // Right side of head curves down
  `C${cx + 46},${base + 30} ${cx + 46},${base + 52} ${cx + 28},${base + 60}`,

  // Bottom of head rounds across
  `C${cx + 16},${base + 66} ${cx - 16},${base + 66} ${cx - 28},${base + 60}`,

  // Left side of head curves back up
  `C${cx - 46},${base + 52} ${cx - 46},${base + 30} ${cx - 32},${base + 22}`,

  // Left neck narrows back
  `C${cx - 14},${base + 12} ${cx - 14},${base - 8} ${cx - 14},${base - 8}`,

  // Left "ear": back to baseline with inward indent
  `C${cx - 36},${base - 8} ${cx - 40},${base} ${cx - 40},${base}`,

  // Continue to left edge
  `H0 Z`,
].join(" ");
---

<div class="w-full leading-none" style={`background-color: ${bottomColor};`}>
  <svg
    viewBox="0 0 1440 115"
    preserveAspectRatio="none"
    class="block w-full h-16 md:h-24"
    fill={topColor}
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d={d} />
  </svg>
</div>
