---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Présentation" },
  { href: "/prix", label: "Prix & Aides" },
  { href: "/contact", label: "Contact" },
];
---

<header class="bg-card/80 backdrop-blur-sm sticky top-0 z-50 border-b border-border/50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-[1140px] mx-auto">
    <a href="/" class="flex items-center gap-3 hover-wiggle">
      <img
        src="/images/logo-recre-reussite-short.png"
        alt="Logo Récré & Réussite"
        class="h-14 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-bold text-sm uppercase tracking-widest transition-colors duration-200",
            currentPath === link.href
              ? "text-cta"
              : "text-text hover:text-primary",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text p-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-card border-t border-border pb-4">
    <ul class="flex flex-col px-6 py-4 gap-3">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block font-bold text-lg py-2 transition-colors",
              currentPath === link.href
                ? "text-cta"
                : "text-text hover:text-primary",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
