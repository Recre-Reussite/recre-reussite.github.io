---
import { Home, Calculator, MessageCircle } from "@lucide/astro";

const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Présentation", icon: Home, color: "text-primary" },
  { href: "/prix", label: "Prix & Aides", icon: Calculator, color: "text-secondary" },
  { href: "/contact", label: "Contact", icon: MessageCircle, color: "text-cta" },
];
---

<header class="bg-card/80 backdrop-blur-sm sticky top-0 z-50 border-b border-border/50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-[1140px] mx-auto">
    <a href="/" class="flex items-center gap-3 hover-wiggle">
      <img
        src="/images/logo-recre-reussite-short.png"
        alt="Logo Récré & Réussite"
        class="h-14 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(({ href, label, icon: Icon, color }) => (
        <a
          href={href}
          class:list={[
            "nav-link flex items-center gap-2 font-bold text-sm uppercase tracking-widest transition-colors duration-200",
            currentPath === href
              ? `text-cta nav-link-active`
              : "text-text hover:text-primary",
          ]}
        >
          <Icon class:list={["w-4 h-4", currentPath === href ? "text-cta" : color]} />
          {label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text p-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-card border-t border-border pb-4">
    <ul class="flex flex-col px-6 py-4 gap-3">
      {links.map(({ href, label, icon: Icon, color }) => (
        <li>
          <a
            href={href}
            class:list={[
              "flex items-center gap-3 font-bold text-lg py-2 transition-colors",
              currentPath === href
                ? "text-cta"
                : "text-text hover:text-primary",
            ]}
          >
            <Icon class:list={["w-5 h-5", currentPath === href ? "text-cta" : color]} />
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
