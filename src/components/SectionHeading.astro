---
interface Props {
  title: string;
  subtitle?: string;
  accent?: string;
  as?: "h1" | "h2";
}

const { title, subtitle, accent, as: Tag = "h2" } = Astro.props;
---

<div class="text-center mb-14">
  {subtitle && (
    <p class="text-text-light uppercase tracking-[0.2em] text-sm font-bold mb-3">
      {subtitle}
    </p>
  )}
  <Tag class="font-display text-primary text-[32px] md:text-[44px] leading-tight">
    <Fragment set:html={accent
      ? title.replace(accent, `<span class="marker-highlight">${accent}</span>`)
      : title
    } />
  </Tag>
</div>
